# Copy this file to .dev.vars and fill in your values.
# .dev.vars is loaded by `wrangler pages dev` and is git-ignored.

# Required for sending quote notification emails (Resend).
EMAIL_FROM=onboarding@resend.dev
EMAIL_TO=you@example.com
RESEND_API_KEY=re_xxxxxxxxxxxx

# Optional: show full error details (message + stack) in API responses.
# DEBUG_EMAIL_ERRORS=1

# Optional: in local dev, skip sending email and return 200 so the form works without Resend.
# Use this to test the form without configuring email.
# DEV_SKIP_EMAIL=1
